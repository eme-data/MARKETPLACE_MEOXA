# ==============================================================
# MEOXA Marketplace - Configuration
# ==============================================================
# Copiez ce fichier en .env et remplissez les valeurs

# --- Base de données PostgreSQL ---
POSTGRES_USER=meoxa
POSTGRES_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_SECURISE
POSTGRES_DB=meoxa_marketplace
DB_PORT=5432

# URL de connexion (ne pas modifier si vous utilisez Docker)
DATABASE_URL=postgresql://meoxa:CHANGEZ_MOI_MOT_DE_PASSE_SECURISE@db:5432/meoxa_marketplace

# --- Application ---
APP_PORT=3000
NEXT_PUBLIC_APP_URL=https://votre-domaine.com
NEXT_PUBLIC_APP_NAME=MEOXA Marketplace

# --- NextAuth ---
NEXTAUTH_URL=https://votre-domaine.com
NEXTAUTH_SECRET=GENEREZ_UNE_CLE_SECRETE_ICI

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXX

# --- Email SMTP ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@meoxa.fr
SMTP_PASSWORD=votre_mot_de_passe_smtp
EMAIL_FROM=MEOXA Marketplace <noreply@meoxa.fr>
